# ================================================
# Frontend API Configuration
# ================================================

# Main college backend used by notifications/notices/tenders/admin.
VITE_API_BASE=https://mmc-backend-production-1fa6.up.railway.app
VITE_API_BASE_URL=https://mmc-backend-production-1fa6.up.railway.app

# ================================================
# OPTION 1: SPLIT MODE
# Main backend on Railway, Hostel ERP on local.
# This matches:
# - notifications backend on Railway
# - Hostel ERP running locally
# ================================================
VITE_ERP_API_BASE=http://127.0.0.1:8000
VITE_ERP_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ================================================
# OPTION 2: BOTH BACKENDS LOCAL
# Uncomment these if the main backend is also local.
# ================================================
# VITE_API_BASE=http://127.0.0.1:8000
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_ERP_API_BASE=http://127.0.0.1:8000
# VITE_ERP_DEV_PROXY_TARGET=http://127.0.0.1:8000

# ================================================
# OPTION 3: BOTH BACKENDS ON RAILWAY
# Uncomment these if Hostel ERP is also deployed.
# ================================================
# VITE_ERP_API_BASE=https://your-hostel-erp-backend.up.railway.app
# VITE_ERP_DEV_PROXY_TARGET=https://your-hostel-erp-backend.up.railway.app
